# ============================================================================
# FLOWTYM PMS — Variables d'environnement (template)
# ============================================================================
# Copier ce fichier en frontend/.env.local pour le développement local.
# NE JAMAIS commiter frontend/.env.local dans git.
# En production, configurer ces variables dans les secrets Vercel/CI.
#
# SECURITY: Aucune valeur réelle ne doit apparaître dans ce fichier.
# ============================================================================

# --- Supabase (OBLIGATOIRE) ------------------------------------------------
# URL de votre projet Supabase (ex: https://abcxyz.supabase.co)
VITE_SUPABASE_URL=

# Clé publique anon (limitée par les RLS — jamais la service_role_key)
VITE_SUPABASE_ANON_KEY=

# --- Backend FastAPI (optionnel en Phase 1+2) -------------------------------
# URL du backend si déployé séparément
# VITE_BACKEND_URL=http://localhost:8001

# --- Backend env (pour backend/server.py) ----------------------------------
# Même URL Supabase que ci-dessus (pour les appels service-role côté backend)
SUPABASE_URL=
# Clé service_role — UNIQUEMENT côté backend, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=
# Activer localhost en CORS (développement local uniquement)
CORS_ALLOW_LOCALHOST=true
# Origines CORS supplémentaires (staging, preview deployments) — séparées par virgule
# CORS_EXTRA_ORIGINS=https://flowtym-staging.vercel.app

# --- Resend (emails ODMS) --------------------------------------------------
RESEND_API_KEY=

# --- Gemini (optionnel) ----------------------------------------------------
GEMINI_API_KEY=

# ============================================================================
# Edge Functions Communication (send-email / send-whatsapp)
# ----------------------------------------------------------------------------
# À configurer dans Supabase > Edge Functions > Secrets (PAS dans le frontend).
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY sont injectés
# automatiquement par Supabase. Les variables ci-dessous sont optionnelles et
# nécessaires uniquement pour le renouvellement automatique des tokens OAuth :
#
#   GOOGLE_CLIENT_ID=         # OAuth client Google (refresh Gmail)
#   GOOGLE_CLIENT_SECRET=
#   MS_CLIENT_ID=             # App registration Microsoft (refresh Graph)
#   MS_CLIENT_SECRET=
#   MS_TENANT_ID=common
#   META_GRAPH_VERSION=v21.0  # Version Graph API WhatsApp Cloud (défaut v21.0)
#
# Les secrets PAR HÔTEL (token Meta, mot de passe SMTP, clé Resend de l'hôtel,
# access/refresh tokens OAuth) ne sont JAMAIS des variables d'environnement :
# ils sont saisis dans Paramètres > Communication et stockés côté serveur dans
# public._hotel_communication_secrets (service_role only, jamais lu au front).
# ============================================================================
